# ---------------------------------------------------------------------------
# RepoHosting — edge function secrets (set via `supabase secrets set ...`)
# Copy to `.env` for local `supabase functions serve`. Never commit real values.
# ---------------------------------------------------------------------------

# The public site origin (used to build OAuth redirect_to URLs)
SITE_URL=http://127.0.0.1:4173

# Vercel OAuth integration (https://vercel.com/dashboard/integrations)
VERCEL_CLIENT_ID=
VERCEL_CLIENT_SECRET=
VERCEL_REDIRECT_URI=

# Netlify OAuth application (https://app.netlify.com/user/applications)
NETLIFY_CLIENT_ID=
NETLIFY_CLIENT_SECRET=
NETLIFY_REDIRECT_URI=

# Render has no OAuth — keys are provided by users at runtime. Nothing to set.

# Supabase injects SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY
# automatically for deployed functions; only set them for local serve if needed.
